generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lesson {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  orderIndex  Int      @default(0)  // stable 1-based position in the source doc
  title       String
  rawContent  String
  contentHash String   @unique
  cards       Card[]
}

model Card {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  type      String      // "vocabulary" | "grammar" | "phrase"
  front     String      // Korean text
  back      String      // English meaning
  notes     String?
  // Dedup key: normalizeFront(front) from lib/card-key.ts. @unique enforces real dedup
  // so an upsert by normalizedFront is safe even across multiple sync calls.
  normalizedFront  String  @unique
  // Raw component lemmas Claude returned: JSON string[] of base-form Hangul.
  // Resolved to CardDependency edges at sync time (two-phase link in sync route).
  components       String?
  // Per-mode content generated at sync time.
  distractors      String?  // JSON array of 3 wrong English meanings (multiple-choice)
  // Legacy cloze columns — kept but no longer written after the Sentence refactor.
  // New cards get Sentence rows instead.
  clozeSentence    String?  // DEPRECATED — use Sentence rows
  clozeAnswer      String?  // DEPRECATED — use Sentence rows
  clozeTranslation String?  // DEPRECATED — use Sentence rows
  // lessonId = the lesson where this card was FIRST introduced (never updated on re-sync).
  lessonId  String?
  lesson    Lesson?     @relation(fields: [lessonId], references: [id])
  review    CardReview?
  sentences Sentence[]
  // Dependency graph: prerequisite edges — cards this card is built from.
  dependencies CardDependency[] @relation("CardToPrereqs")
  // Reverse relation: cards that depend on this one.
  requiredBy   CardDependency[] @relation("PrereqToCards")
  // Append-only review history (HIST-01).
  reviewLogs   ReviewLog[]

  @@index([lessonId])
}

// A natural Korean example sentence for a Card, with the target word/pattern
// highlighted. Sentences are presentation context only — Card is still the FSRS unit.
// Each card may have 1–3 sentences (stored with orderIndex 0, 1, 2).
// The shown sentence rotates across reviews: (hashStr(card.id) + reps) % len.
model Sentence {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  korean      String   // full sentence, NO blank — e.g. "저는 매일 학교에 가요"
  targetForm  String   // exact surface form to highlight/blank — e.g. "가요"
  translation String   // English — e.g. "I go to school every day"
  orderIndex  Int      @default(0)  // order within this card's sentence list
}

model CardReview {
  id            String    @id @default(cuid())
  cardId        String    @unique
  card          Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  state         Int       @default(0)    // 0=New, 1=Learning, 2=Review, 3=Relearning
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0)
  scheduledDays Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  nextReview    DateTime  @default(now())
  lastReview    DateTime?
}

// Append-only audit log of every individual review (HIST-01). Unlike CardReview
// (one row per card, current FSRS state), ReviewLog stores the full post-update
// FSRS snapshot at the time of each review — cardId is NOT unique (many rows per
// card). idempotencyKey is the DB-level source of truth that makes lost-response
// retries safe to replay without double-applying a rating (HIST-02).
model ReviewLog {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  cardId         String
  card           Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  rating         Int      // FSRS grade 1-4 (Again/Hard/Good/Easy)
  idempotencyKey String   @unique
  // Resulting (post-update) FSRS snapshot — same shape as CardReview.
  state          Int
  stability      Float
  difficulty     Float
  elapsedDays    Int
  scheduledDays  Int
  reps           Int
  lapses         Int
  nextReview     DateTime
  lastReview     DateTime?

  @@index([cardId])
  @@index([createdAt])
}

// A directed prerequisite edge: `card` is built from `prerequisite`.
// Created at sync time by resolving Card.components → matching Card.normalizedFront.
// Scoped to the in-session card set at study time to drive blended sequencing.
model CardDependency {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  cardId         String
  prerequisiteId String
  card           Card     @relation("CardToPrereqs", fields: [cardId], references: [id], onDelete: Cascade)
  prerequisite   Card     @relation("PrereqToCards", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  @@unique([cardId, prerequisiteId])
  @@index([cardId])
  @@index([prerequisiteId])
}

// Per-day active study time, for the habit streak/heatmap.
model StudyDay {
  id        String   @id @default(cuid())
  date      String   @unique   // user-LOCAL calendar day, "YYYY-MM-DD"
  seconds   Int      @default(0)
  reviews   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Generic key/value app settings (e.g. "dailyGoalSeconds").
model Setting {
  key   String @id
  value String
}
