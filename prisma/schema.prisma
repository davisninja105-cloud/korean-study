generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lesson {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  orderIndex  Int      @default(0)  // stable 1-based position in the source doc
  title       String
  rawContent  String
  contentHash String   @unique
  cards       Card[]
}

model Card {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  type      String      // "vocabulary" | "grammar" | "phrase"
  front     String      // Korean text
  back      String      // English meaning
  notes     String?
  // Per-mode content generated at sync time.
  distractors      String?  // JSON array of 3 wrong English meanings (multiple-choice)
  // Legacy cloze columns — kept but no longer written after the Sentence refactor.
  // New cards get Sentence rows instead. Backfilled via scripts/backfill-sentences.mjs.
  clozeSentence    String?  // DEPRECATED — use Sentence rows
  clozeAnswer      String?  // DEPRECATED — use Sentence rows
  clozeTranslation String?  // DEPRECATED — use Sentence rows
  lessonId  String?
  lesson    Lesson?     @relation(fields: [lessonId], references: [id])
  review    CardReview?
  sentences Sentence[]
}

// A natural Korean example sentence for a Card, with the target word/pattern
// highlighted. Sentences are presentation context only — Card is still the FSRS unit.
// Each card may have 1–3 sentences (stored with orderIndex 0, 1, 2).
// The shown sentence rotates across reviews: (hashStr(card.id) + reps) % len.
model Sentence {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  korean      String   // full sentence, NO blank — e.g. "저는 매일 학교에 가요"
  targetForm  String   // exact surface form to highlight/blank — e.g. "가요"
  translation String   // English — e.g. "I go to school every day"
  orderIndex  Int      @default(0)  // order within this card's sentence list
}

model CardReview {
  id            String    @id @default(cuid())
  cardId        String    @unique
  card          Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  state         Int       @default(0)    // 0=New, 1=Learning, 2=Review, 3=Relearning
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0)
  scheduledDays Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  nextReview    DateTime  @default(now())
  lastReview    DateTime?
}

// Per-day active study time, for the habit streak/heatmap.
model StudyDay {
  id        String   @id @default(cuid())
  date      String   @unique   // user-LOCAL calendar day, "YYYY-MM-DD"
  seconds   Int      @default(0)
  reviews   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Generic key/value app settings (e.g. "dailyGoalSeconds").
model Setting {
  key   String @id
  value String
}
