# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local sqlite database
dev.db
dev.db-journal
*.db

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# GSD planning tool research cache (ephemeral, not meaningful history)
.planning/**/.cache/

# Phase 24 diagnosis script scratch dir: isolated test DB + WAL/SHM companion
# files (from the WAL journal-mode pragma) + raw run logs. *.db above already
# covers the .db file itself, but not -shm/-wal or the .log — ignore the
# whole scratch dir so no diagnosis-run artifact is ever accidentally staged.
/scripts/.tmp/

# Phase 25 Playwright E2E harness: reusable storageState (a real session
# cookie), Playwright's own report/artifact dirs, and the isolated E2E test
# DB's scratch dir (*.db above already covers the .db file itself, but not
# its -wal/-shm sidecars).
/playwright/.auth/
/playwright-report/
/test-results/
/e2e/.tmp/

# Phase 27 Plan 03: @playwright/mcp writes console logs and page snapshots
# here during agent-driven exploratory QA sessions (Playwright MCP server).
/.playwright-mcp/
